<!-- Regla: Detección de Fuerza Bruta SSH -->
<!-- Lógica: 10 o más fallos SSH desde la misma IP en 60s (regla base 5760). -->
<!-- La regla 100002 se monta sobre la deteccion nativa 5763 como respaldo.  -->
<group name="local,ssh,">

  <rule id="100001" level="10" frequency="10" timeframe="60">
    <if_matched_sid>5760</if_matched_sid>
    <same_source_ip />
    <description>Ataque de fuerza bruta SSH detectado desde $(srcip)</description>
    <group>authentication_failures,brute_force</group>
  </rule>

  <rule id="100002" level="10">
    <if_sid>5763</if_sid>
    <description>Ataque de fuerza bruta SSH confirmado desde $(srcip)</description>
    <group>authentication_failures,brute_force</group>
  </rule>

</group>

<!-- Regla: Detección de Exfiltración de Datos -->
<!-- Lógica de correlacion:                                              -->
<!-- 1) Login SSH exitoso fuera del horario laboral (22:00-06:00).       -->
<!-- 2) Seguido de una transferencia de datos saliente > 500 MB.         -->
<!-- Ambas condiciones juntas = nivel 14 (critico, exfiltracion).        -->
<group name="local,exfiltration,">

  <rule id="100010" level="6">
    <if_sid>5715</if_sid>
    <time>22:00 - 06:00</time>
    <description>Login SSH exitoso fuera del horario laboral desde $(srcip)</description>
    <group>after_hours_login</group>
  </rule>

  <rule id="100011" level="14" timeframe="3600">
    <if_matched_sid>100010</if_matched_sid>
    <same_source_ip />
    <description>CRITICO: Posible exfiltracion de datos (transferencia masiva tras login fuera de horario) desde $(srcip)</description>
    <group>data_exfiltration,high_risk</group>
  </rule>

</group>
